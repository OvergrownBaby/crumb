# Mock data toggle — true = use seeded mock data, false = call live APIs
NEXT_PUBLIC_USE_MOCK_DATA=false

# Gemini (https://aistudio.google.com/app/apikey) — for video extraction
GEMINI_API_KEY=

# Anthropic (https://console.anthropic.com) — for text extraction
ANTHROPIC_API_KEY=

# Google Places API (https://console.cloud.google.com) — enable Places API (New)
# and Geocoding API. 10K free calls/month, requires billing card.
GOOGLE_PLACES_API_KEY=

# Supabase (https://supabase.com/dashboard) — create a new project,
# then copy from Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_PROJECT_ID=
